# Copy this file to .env and fill in your values
# For Coolify: set these as Environment Variables in the service settings

# ─── Database (Aiven MySQL) ───────────────────────────────────────────────────
DB_HOST=mysql-xxxxxxxx.c.aivencloud.com
DB_PORT=24923
DB_USER=avnadmin
DB_PASSWORD=your_aiven_password
DB_NAME=defaultdb
DB_SSL_CA=../ca.pem

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3001
# Set this to your Coolify public URL so the keep-alive ping works
PUBLIC_URL=https://your-app.yourdomain.com
NVIDIA_API_KEY=your_api_key_here
